# Supabase — Public keys (safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# HDFC SmartGateway — No frontend keys needed!
# All HDFC credentials are stored ONLY in Supabase Edge Function secrets.
# This is more secure than Razorpay which needed a frontend publishable key.

# ─── NEVER put these in VITE_ prefixed vars ───
# SUPABASE_SERVICE_ROLE_KEY → only in Supabase Edge Function secrets
# HDFC_API_KEY → only in Supabase Edge Function secrets
# HDFC_MERCHANT_ID → only in Supabase Edge Function secrets
# HDFC_RESELLER_ID → only in Supabase Edge Function secrets (default: hdfc_reseller)
# HDFC_PAYMENT_PAGE_CLIENT_ID → only in Supabase Edge Function secrets
# HDFC_BASE_URL → only in Supabase Edge Function secrets
#   Sandbox: https://smartgateway.hdfcuat.bank.in
#   Production: https://smartgateway.hdfc.bank.in
# HDFC_WEBHOOK_USERNAME → only in Supabase Edge Function secrets
# HDFC_WEBHOOK_PASSWORD → only in Supabase Edge Function secrets
# PAYMENT_RETURN_URL → only in Supabase Edge Function secrets
#   Example: https://noc.yourdomain.com/payment/callback
# ALLOWED_ORIGIN → set to your production URL (e.g. https://noc.yourdomain.com)
