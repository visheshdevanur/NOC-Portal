# Supabase — Public keys (safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay — Publishable key only (safe to expose in browser)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ─── NEVER put these in VITE_ prefixed vars ───
# SUPABASE_SERVICE_ROLE_KEY → only in Supabase Edge Function secrets
# RAZORPAY_KEY_SECRET → only in Supabase Edge Function secrets
# RAZORPAY_WEBHOOK_SECRET → only in Supabase Edge Function secrets
# ALLOWED_ORIGIN → set to your production URL (e.g. https://noc.yourdomain.com)
