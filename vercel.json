{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",

  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://smartgateway.hdfc.bank.in https://smartgateway.hdfcuat.bank.in; img-src 'self' data: blob: https:; frame-src https://smartgateway.hdfc.bank.in https://smartgateway.hdfcuat.bank.in" }
      ]
    }
  ],

  "rewrites": [
    { "source": "/payment/callback", "destination": "/index.html" },
    { "source": "/((?!assets|favicon\\.svg|icons\\.svg|_redirects).*)", "destination": "/index.html" }
  ]
}
